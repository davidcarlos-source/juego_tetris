{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build tetris",
            "type": "shell",
            "command": "cmd",
            "args": ["/c", "build.bat"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run tetris",
            "type": "shell",
            "command": ".\\tetris.exe",
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}
